AZURE_AI_PROJECT_ENDPOINT="https://your-resource.services.ai.azure.com/api/projects/YOUR_PROJECT_NAME"
AZURE_OPENAI_ENDPOINT="https://your-azure-openai-resource.openai.azure.com"
# Optional alternative to AZURE_OPENAI_ENDPOINT.
# AZURE_OPENAI_API_BASE="https://your-azure-openai-resource.openai.azure.com/openai/v1/"
OPENAI_API_VERSION="2024-08-01-preview"
# Deployment name for the summarization model, not the model ID.
AZURE_OPENAI_DEPLOYMENT="your-summary-deployment-name"
# Deployment name for the transcription model, not the model ID.
AZURE_OPENAI_TRANSCRIBE_DEPLOYMENT="your-transcribe-deployment-name"
# Optional: set to json for deployments that do not support verbose_json.
# AZURE_OPENAI_TRANSCRIBE_RESPONSE_FORMAT="json"
# Realtime record page: deployment name for the websocket session.
# Use a realtime-capable deployment such as gpt-realtime-mini, not the batch transcription deployment.
AZURE_OPENAI_REALTIME_TRANSCRIBE_DEPLOYMENT="your-realtime-transcribe-deployment-name"
# Optional raw built-in input transcription model ID sent in the realtime session.
# This is not the websocket deployment name.
# AZURE_OPENAI_REALTIME_TRANSCRIBE_MODEL="gpt-4o-transcribe"
# Optional realtime websocket API version.
# AZURE_OPENAI_REALTIME_API_VERSION="2024-10-01-preview"
# Optional token scope override. Azure OpenAI resource endpoints default to
# https://cognitiveservices.azure.com/.default, and Azure AI project endpoints
# automatically switch to https://ai.azure.com/.default.
# AZURE_OPENAI_SCOPE="https://cognitiveservices.azure.com/.default"
# Optional Record-page-specific scope override.
# AZURE_OPENAI_REALTIME_SCOPE="https://cognitiveservices.azure.com/.default"
# Optional on Windows: fall back to authenticated WSL Azure CLI credentials.
# AZURE_OPENAI_USE_WSL_AZ_CLI="1"

GITHUB_TOKEN=your_github_token_here
